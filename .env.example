# =============================================================================
# CLV Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your token:
#   copy .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ── DagsHub / MLflow ────────────────────────────────────────────────────────
# 1. Go to https://dagshub.com/kajoldave8/clv-engine → Experiments tab
# 2. Go to User Settings → Tokens → create an access token
#
DAGSHUB_MLFLOW_URI=https://dagshub.com/kajoldave8/clv-engine.mlflow
DAGSHUB_USER_TOKEN=<paste-your-token-here>
